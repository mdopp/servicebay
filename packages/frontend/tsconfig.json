{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/components/*": ["./src/components/*"],
      "@/config/*": ["./src/config/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/dashboards/*": ["./src/dashboards/*"],
      "@/providers/*": ["./src/providers/*"],
      "@/app/*": ["./src/app/*"],
      "@/lib/*": ["../backend/src/lib/*"],
      "@/*": ["./src/*"],
      "@servicebay/api-client": ["../api-client/src/index.ts"],
      "@servicebay/api-client/*": ["../api-client/src/*"],
      "@servicebay/frontend/*": ["./src/*"],
      "@servicebay/backend/*": ["../backend/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}

{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@/components/*": ["./packages/frontend/src/components/*"],
      "@/hooks/*": ["./packages/frontend/src/hooks/*"],
      "@/dashboards/*": ["./packages/frontend/src/dashboards/*"],
      "@/providers/*": ["./packages/frontend/src/providers/*"],
      "@servicebay/api-client": ["./packages/api-client/src/index.ts"],
      "@servicebay/api-client/*": ["./packages/api-client/src/*"],
      "@servicebay/frontend/*": ["./packages/frontend/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "packages/*/src/**/*.ts"
  ],
  "exclude": ["node_modules", "scratch"]
}

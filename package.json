{
  "name": "servicebay",
  "version": "4.13.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "fuser -k 3000/tcp || true && tsx server.ts",
    "dev:frontend": "fuser -k 3001/tcp || true && NEXT_PUBLIC_USE_MOCKS=1 next dev --port 3001",
    "storybook": "storybook dev --port 6006",
    "build-storybook": "storybook build --output-dir storybook-static",
    "test-storybook": "test-storybook --url http://localhost:6006",
    "build": "next build --webpack && node scripts/patch-routes-manifest.mjs && node scripts/build-server.mjs",
    "start": "NODE_ENV=production node dist-server/server.cjs",
    "lint": "eslint",
    "knip": "knip",
    "test": "vitest run",
    "gen-template-docs": "tsx scripts/gen-template-docs.ts",
    "check:invariants": "tsx scripts/check-invariants.ts",
    "check:deps": "depcruise --config .dependency-cruiser.cjs src packages server.ts",
    "check:arch": "npm run check:invariants && npm run check:deps",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.py": [
      "python3 -m py_compile"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@servicebay/api-client": "*",
    "@tailwindcss/typography": "^0.5.19",
    "@xyflow/react": "^12.10.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.1.3",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.562.0",
    "mustache": "^4.2.0",
    "next": "16.2.4",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/env": "16.2.4",
    "@storybook/nextjs": "^10.4.0",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/mustache": "^4.2.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/semver": "^7.7.1",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^5.1.2",
    "dependency-cruiser": "^17.4.0",
    "esbuild": "^0.27.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-unused-imports": "^4.3.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "knip": "^5.81.0",
    "lint-staged": "^16.2.7",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "postcss": "^8.5.10",
    "storybook": "^10.4.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.16",
    "wait-on": "^9.0.10"
  },
  "knip": {
    "ignoreBinaries": [
      "fuser",
      "python3",
      "playwright"
    ],
    "ignore": [
      "scripts/check-invariants.ts",
      "packages/frontend/public/mockServiceWorker.js",
      ".storybook/stubs/empty.js",
      ".storybook/stubs/empty-loader.cjs"
    ],
    "ignoreExportsUsedInFile": true,
    "workspaces": {
      ".": {
        "entry": [
          "src/app/**/page.tsx",
          "src/app/**/layout.tsx",
          "src/app/**/route.ts",
          "src/app/**/loading.tsx",
          "src/app/**/error.tsx",
          "src/app/**/not-found.tsx",
          "scripts/**/*.{ts,mjs}"
        ]
      },
      "packages/frontend": {
        "entry": [
          "src/**/*.{ts,tsx}"
        ],
        "ignoreDependencies": [
          "msw-storybook-addon"
        ]
      },
      "packages/backend": {
        "entry": [
          "src/**/*.ts"
        ]
      }
    }
  },
  "overrides": {
    "ellipsize": "^0.7.0",
    "react-highlight-words": {
      "react": "$react"
    },
    "postcss": "^8.5.10"
  },
  "msw": {
    "workerDirectory": [
      "packages/frontend/public"
    ]
  }
}

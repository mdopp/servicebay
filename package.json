{
  "name": "servicebay",
  "version": "4.87.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "predev": "node scripts/predev.mjs",
    "predev:frontend": "node scripts/predev.mjs",
    "dev": "fuser -k 3000/tcp || true && tsx packages/backend/src/server.ts",
    "dev:frontend": "fuser -k 3001/tcp || true && NEXT_PUBLIC_USE_MOCKS=1 next dev packages/frontend --port 3001",
    "build": "next build packages/frontend && node scripts/patch-routes-manifest.mjs && node scripts/build-server.mjs",
    "start": "NODE_ENV=production node dist-server/server.cjs",
    "lint": "eslint",
    "knip": "knip",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:diff-coverage": "tsx scripts/check-diff-coverage.ts",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "gen-template-docs": "tsx scripts/gen-template-docs.ts",
    "sb-config-upload": "tsx scripts/sb-config-upload.ts",
    "check:invariants": "tsx scripts/check-invariants.ts",
    "check:deps": "depcruise --config .dependency-cruiser.cjs packages/frontend/src packages/backend/src",
    "check:arch": "npm run check:invariants && npm run check:deps",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.py": [
      "python3 -m py_compile"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@servicebay/api-client": "*",
    "@tailwindcss/typography": "^0.5.19",
    "@xyflow/react": "^12.11.0",
    "basic-ftp": "^6.0.1",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "js-yaml": "^4.2.0",
    "lucide-react": "^1.17.0",
    "mustache": "^4.2.0",
    "next": "16.2.7",
    "qrcode.react": "^4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/env": "16.2.7",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/mustache": "^4.2.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/semver": "^7.7.1",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "4.1.8",
    "dependency-cruiser": "^17.4.3",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "knip": "^6.15.0",
    "lint-staged": "^16.2.7",
    "msw": "^2.14.6",
    "postcss": "^8.5.10",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^6",
    "vitest": "^4.0.16"
  },
  "knip": {
    "ignoreBinaries": [
      "fuser",
      "python3"
    ],
    "ignore": [
      "scripts/check-invariants.ts",
      "packages/frontend/public/mockServiceWorker.js"
    ],
    "ignoreExportsUsedInFile": true,
    "workspaces": {
      ".": {
        "entry": [
          "scripts/**/*.{ts,mjs}",
          "tests/e2e/**/*.e2e.ts"
        ],
        "ignoreDependencies": [
          "@servicebay/api-client",
          "lucide-react",
          "react-markdown",
          "socket.io-client"
        ]
      },
      "packages/frontend": {
        "entry": [
          "src/app/**/page.tsx",
          "src/app/**/layout.tsx",
          "src/app/**/route.ts",
          "src/app/**/loading.tsx",
          "src/app/**/error.tsx",
          "src/app/**/not-found.tsx",
          "src/mocks/browser.ts",
          "src/**/*.{ts,tsx}"
        ]
      },
      "packages/backend": {
        "entry": [
          "src/**/*.ts"
        ]
      }
    }
  },
  "overrides": {
    "ellipsize": "^0.7.0",
    "react-highlight-words": {
      "react": "$react"
    },
    "postcss": "^8.5.10"
  },
  "msw": {
    "workerDirectory": [
      "packages/frontend/public"
    ]
  }
}

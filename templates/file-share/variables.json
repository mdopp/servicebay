{
  "SHARE_USER": {
    "type": "text",
    "description": "Samba username for file share access",
    "default": "samba"
  },
  "SHARE_PASSWORD": {
    "type": "password",
    "description": "Samba password for file share access"
  },
  "SYNCTHING_SUBDOMAIN": {
    "type": "subdomain",
    "description": "Subdomain for Syncthing Web UI",
    "default": "sync",
    "proxyPort": "8384",
    "proxyConfig": {
      "allow_websocket_upgrade": true,
      "block_exploits": true,
      "ssl_forced": true
    }
  }
}

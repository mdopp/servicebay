{
  "NGINX_PORT": {
    "type": "text",
    "description": "HTTP port",
    "default": "8080"
  },
  "NGINX_SSL_PORT": {
    "type": "text",
    "description": "HTTPS port",
    "default": "8443"
  },
  "NGINX_ADMIN_PORT": {
    "type": "text",
    "description": "Admin UI port",
    "default": "8081"
  },
  "PUBLIC_DOMAIN": {
    "type": "text",
    "description": "Public domain for all services (e.g. dopp.cloud)",
    "default": "dopp.cloud"
  },
  "NPM_SUBDOMAIN": {
    "type": "subdomain",
    "description": "Subdomain for Nginx Proxy Manager admin",
    "default": "nginx",
    "proxyPort": "NGINX_ADMIN_PORT",
    "proxyConfig": {
      "block_exploits": true,
      "ssl_forced": true
    }
  }
}

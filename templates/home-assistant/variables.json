{
  "TZ": {
    "type": "text",
    "description": "Timezone (used by HA, Z-Wave JS and Matter Server for log/scheduling timestamps)",
    "default": "Europe/Berlin"
  },
  "ZWAVE_SECRET": {
    "type": "secret",
    "description": "Random string for Z-Wave JS session security (auto-generated)"
  },
  "ZWAVE_DEVICE": {
    "type": "device",
    "description": "USB device path for your Z-Wave stick",
    "devicePath": "/dev/serial/by-id"
  },
  "HA_SUBDOMAIN": {
    "type": "subdomain",
    "description": "Subdomain for Home Assistant",
    "default": "home",
    "exposure": "public",
    "proxyPort": "8123",
    "proxyConfig": {
      "allow_websocket_upgrade": true,
      "block_exploits": true,
      "ssl_forced": true,
      "advanced_config": "proxy_read_timeout 86400;\nproxy_send_timeout 86400;\nproxy_buffering off;"
    },
    "oidcClient": {
      "client_id": "homeassistant",
      "client_name": "Home Assistant",
      "authorization_policy": "one_factor",
      "redirect_uris": ["/auth/oidc/callback"],
      "scopes": ["openid", "profile", "email", "groups"]
    }
  }
}

{
  "VAULTWARDEN_PORT": {
    "type": "text",
    "description": "Web UI port",
    "default": "8222"
  },
  "VAULTWARDEN_DOMAIN": {
    "type": "text",
    "description": "Public URL (z.B. https://vault.example.com)",
    "default": ""
  },
  "VAULTWARDEN_SIGNUPS": {
    "type": "select",
    "description": "Registrierungen erlauben",
    "options": ["true", "false"],
    "default": "true"
  },
  "VAULTWARDEN_SUBDOMAIN": {
    "type": "subdomain",
    "description": "Subdomain for Vaultwarden",
    "default": "vault",
    "proxyPort": "VAULTWARDEN_PORT",
    "proxyConfig": {
      "allow_websocket_upgrade": true,
      "block_exploits": true,
      "http2_support": false,
      "ssl_forced": true
    },
    "oidcClient": {
      "client_id": "vaultwarden",
      "client_name": "Vaultwarden",
      "authorization_policy": "one_factor",
      "redirect_uris": ["/identity/connect/authorize"],
      "scopes": ["openid", "profile", "email", "groups"]
    }
  }
}

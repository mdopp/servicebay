---
# Authelia Configuration
# Generated by ServiceBay — edit via ServiceBay or this file directly

theme: dark

server:
  address: 'tcp://0.0.0.0:{{AUTHELIA_PORT}}'

log:
  level: info

jwt_secret: '{{AUTHELIA_JWT_SECRET}}'

authentication_backend:
  ldap:
    address: 'ldap://{{LLDAP_HOST}}:{{LLDAP_LDAP_PORT}}'
    base_dn: '{{LLDAP_BASE_DN}}'
    additional_users_dn: 'ou=people'
    users_filter: '(&(|({username_attribute}={input})({mail_attribute}={input}))(objectClass=person))'
    additional_groups_dn: 'ou=groups'
    groups_filter: '(member={dn})'
    user: 'uid=admin,ou=people,{{LLDAP_BASE_DN}}'
    password: '{{LLDAP_ADMIN_PASSWORD}}'
    attributes:
      username: 'uid'
      display_name: 'displayName'
      mail: 'mail'
      group_name: 'cn'

session:
  secret: '{{AUTHELIA_SESSION_SECRET}}'
  cookies:
    - domain: '{{PUBLIC_DOMAIN}}'
      authelia_url: 'https://auth.{{PUBLIC_DOMAIN}}'

storage:
  encryption_key: '{{AUTHELIA_STORAGE_ENCRYPTION_KEY}}'
  local:
    path: '/data/db.sqlite3'

notifier:
  filesystem:
    filename: '/data/notification.txt'

access_control:
  default_policy: deny
  rules:
    # Authelia portal — must be publicly accessible
    - domain: 'auth.{{PUBLIC_DOMAIN}}'
      policy: bypass

    # Admin services — admins group, two-factor
    - domain:
        - 'admin.{{PUBLIC_DOMAIN}}'
        - 'nginx.{{PUBLIC_DOMAIN}}'
        - 'dns.{{PUBLIC_DOMAIN}}'
        - 'ldap.{{PUBLIC_DOMAIN}}'
      policy: two_factor
      subject:
        - 'group:admins'

    # Everything else — family + admins, one-factor
    - domain: '*.{{PUBLIC_DOMAIN}}'
      policy: one_factor
      subject:
        - 'group:family'
        - 'group:admins'

identity_providers:
  oidc:
    hmac_secret: '{{AUTHELIA_OIDC_HMAC_SECRET}}'
    jwks:
      # Authelia 4.39+ requires a real key — ServiceBay writes a 2048-bit RSA
      # private key to /config/oidc.pem at install time (auto-generated).
      - key_id: 'main'
        algorithm: 'RS256'
        use: 'sig'
        key_path: '/config/oidc.pem'
    clients:
      - client_id: 'servicebay'
        client_name: 'ServiceBay'
        client_secret: '$plaintext$servicebay-oidc-secret'
        public: false
        authorization_policy: 'two_factor'
        redirect_uris:
          - 'https://admin.{{PUBLIC_DOMAIN}}/api/auth/oidc/callback'
        scopes:
          - 'openid'
          - 'profile'
          - 'email'
          - 'groups'
        # 'groups' claim is delivered automatically when the 'groups' scope is
        # requested — no client-level claim mapping needed in 4.39+.
        response_types:
          - 'code'
        grant_types:
          - 'authorization_code'
        token_endpoint_auth_method: 'client_secret_post'
      # Additional OIDC clients are declared by their respective service templates
